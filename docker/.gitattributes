# Sprint 1 — Windows/Mac/Linux 라인엔딩 일관성
# bash 스크립트와 Docker 관련 파일은 LF 강제 (R5 대응)

* text=auto

*.sh              text eol=lf
*.yml             text eol=lf
*.yaml            text eol=lf
*.env             text eol=lf
*.env.example     text eol=lf
Dockerfile        text eol=lf
Dockerfile.*      text eol=lf
docker-compose*   text eol=lf
*.sql             text eol=lf
*.py              text eol=lf
